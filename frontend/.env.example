# ===========================================================================
# Finora — Frontend environment variables
# ---------------------------------------------------------------------------
# Copy this file to frontend/.env for local dev. In production these are
# set in the Vercel project settings → Environment Variables.
#
# All Create-React-App env vars MUST start with REACT_APP_ to be exposed
# to the browser bundle.
# ===========================================================================

# Base URL of the backend API, including the /api prefix.
# Local dev:    http://localhost:8081/api
# Production:   https://finora-backend-rnd0.onrender.com/api
REACT_APP_API_URL=http://localhost:8081/api

# Sentry — sign up at https://sentry.io, create a "React" project, paste the DSN.
# Leaving these blank is safe — the SDK no-ops without a DSN.
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENV=development
