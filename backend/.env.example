# ===========================================================================
# Finora — Backend environment variables
# ---------------------------------------------------------------------------
# Copy this file to backend/.env and fill in real values for local dev.
# In production these are configured in the Render dashboard under
# Environment → Add Environment Variable.
# ===========================================================================

# --- App URLs ---------------------------------------------------------------
# Public URL of the deployed React app (used to build OAuth redirects + links
# in password-reset emails).
FRONTEND_URL=http://localhost:3000

# Public URL of this backend service (used by the OAuth2 redirect URI).
BACKEND_URL=http://localhost:8081

# --- Database (Supabase Postgres — Session Pooler URL) ---------------------
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# Convert "postgresql://..." to "jdbc:postgresql://..." for Spring Boot.
DATABASE_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_USER=postgres.<your-project-ref>
DATABASE_PASSWORD=replace-me

# --- JWT ---------------------------------------------------------------------
# At LEAST 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters

# --- Google OAuth2 client ----------------------------------------------------
# https://console.cloud.google.com/apis/credentials → "Create OAuth client ID"
# Authorized redirect URI must match: ${BACKEND_URL}/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Gmail SMTP, app password — not your Google account password) ----
# https://myaccount.google.com/apppasswords
MAIL_NAME=your-gmail@gmail.com
MAIL_PASSWORD=

# --- LLM provider ------------------------------------------------------------
# Either "gemini" (default, free tier) or "ollama" (local self-hosted only).
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini. Get a free key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Required when LLM_PROVIDER=ollama. Run `ollama serve` and `ollama pull mistral:7b`.
# Render free tier cannot host Ollama — use this only locally.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# --- Redis cache (Redis Cloud free tier — used in Phase 2) ------------------
# REDIS_URL=redis://default:<password>@<host>:<port>

# --- Sentry (optional — used in Phase 2) ------------------------------------
# SENTRY_DSN=

# --- Hibernate / Flyway emergency override ----------------------------------
# Leave unset in normal operation (defaults to "validate"). If a schema
# mismatch blocks startup after Flyway adoption, set DDL_AUTO=update once
# to let Hibernate self-heal, then unset.
# DDL_AUTO=validate

# --- Optional: server port (Render sets PORT automatically) -----------------
# PORT=8081
